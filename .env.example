# Trading 212 Environment (demo or live)
ENVIRONMENT=demo

# Trading 212 Demo API
T212_DEMO_API_KEY=your_trading_212_demo_api_key_here
T212_DEMO_API_SECRET=your_trading_212_demo_api_secret_here
T212_DEMO_BASE_URL=https://demo.trading212.com/api/v0

# Trading 212 Live API
T212_LIVE_API_KEY=your_trading_212_live_api_key_here
T212_LIVE_API_SECRET=your_trading_212_live_api_secret_here
T212_LIVE_BASE_URL=https://live.trading212.com/api/v0

# Supabase
SUPABASE_URL=your_supabase_url_here
SUPABASE_SERVICE_KEY=your_supabase_service_key_here
